# Express Backend Settings
PORT=3001
# Optional — usually NOT needed on Vercel (vercel.json proxies /api/* to Railway).
# If set, must be a full https URL. Wrong values break Save & Publish.
# VITE_BACKEND_URL=https://assitly-ai-dm-production.up.railway.app
INSTAGRAM_VERIFY_TOKEN=your_webhook_verify_token
# Public URL Meta calls (ngrok or production) — used by Sync webhooks
WEBHOOK_CALLBACK_URL=https://your-ngrok-url.ngrok-free.dev/api/webhooks/instagram

# Firebase Configuration (client — VITE_* exposed to browser)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id",...}

# Meta / Instagram OAuth
VITE_META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
VITE_META_CONFIG_ID=your_meta_config_id

# Dev-only sandbox (ignored when NODE_ENV=production)
TEST_IG_ACCESS_TOKEN=
TEST_IG_ACCOUNT_ID=

# Database (Prisma — billing & trials)
DATABASE_URL="file:./prisma/dev.db"

# Razorpay (AssistlyDM billing only — https://dashboard.razorpay.com)
# Use AssistlyDM-dedicated plan IDs. Plan names must include "AssistlyDM" and match:
#   Monthly = ₹99 (9900 paise)  |  Yearly = ₹999 (99900 paise)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_YEARLY=
